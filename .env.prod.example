# PostgreSQL
POSTGRES_DB=apni_kirana_store
POSTGRES_USER=postgres
POSTGRES_PASSWORD=zxcvbnmn

# Redis
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# Backend
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://postgres:zxcvbnmn@postgres:5432/apni_kirana_store
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379
JWT_ACCESS_SECRET=CHANGE_THIS_64CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_THIS_DIFFERENT_64CHAR_STRING

# ─── SMS provider for OTP ─────────────────────────────────────────────────
# Pick ONE provider and set SMS_PROVIDER + that provider's credentials.
#   CONSOLE   = log to backend stdout (DEV ONLY — never set this in prod)
#   TWOFACTOR = 2Factor.in (free 100/day, India) — recommended for India launch
#   MSG91     = MSG91 (~₹0.18/OTP, India, no daily cap) — for higher volume
#   TWILIO    = international, ~₹3.30/OTP in India
# See docs/deployment.md § SMS OTP setup for sign-up steps.
SMS_PROVIDER=TWOFACTOR

# 2Factor.in — required when SMS_PROVIDER=TWOFACTOR
TWOFACTOR_API_KEY=
TWOFACTOR_TEMPLATE=OTP1

# MSG91 — required when SMS_PROVIDER=MSG91
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Twilio — required when SMS_PROVIDER=TWILIO
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Cloudinary (image uploads) ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Firebase (FCM fallback for raw FCM tokens) ──────────────────────────
# Optional: only needed if you want to receive raw FCM tokens (not Expo
# tokens). Mobile apps use Expo Push by default which doesn't need Firebase.
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── Web Push for admin browser (VAPID keys) ─────────────────────────────
# Generate once with:  npx web-push generate-vapid-keys --json
# Don't rotate without re-subscribing every browser.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ─── Razorpay (payments) ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

CORS_ORIGIN=https://admin.yourdomain.com

# ─── Admin (Next.js) ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
