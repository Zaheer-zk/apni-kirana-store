# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/apni_kirana_store

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# SMS provider for OTP. CONSOLE (dev) | TWOFACTOR | MSG91 | TWILIO
SMS_PROVIDER=CONSOLE

# Twilio (used when SMS_PROVIDER=TWILIO)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# 2Factor.in (used when SMS_PROVIDER=TWOFACTOR — 100 OTP/day free forever)
TWOFACTOR_API_KEY=
TWOFACTOR_TEMPLATE=OTP1

# MSG91 (used when SMS_PROVIDER=MSG91 — Indian provider, ~₹0.18/OTP)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Cloudinary (Image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# Razorpay (Payments)
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# CORS
CORS_ORIGIN=http://localhost:8081

# Web Push (admin browser notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
